{
  "name": "@boilerplate/desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Electron desktop wrapper for Boilerplate App (Windows EXE)",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && electron .",
    "dev:watch": "tsc --watch",
    "build": "tsc",
    "dist": "npm run build && electron-builder --win nsis --publish never",
    "dist:portable": "npm run build && electron-builder --win nsis portable --publish never",
    "dist:all": "npm run build && electron-builder --win nsis portable --publish never"
  },
  "keywords": [],
  "author": "Aniston Technologies LLP",
  "license": "UNLICENSED",
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3"
  },
  "build": {
    "appId": "com.aniston.boilerplate",
    "productName": "Boilerplate App",
    "copyright": "Copyright © 2025 Aniston Technologies LLP",
    "directories": {
      "output": "dist-release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "app",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Boilerplate App",
      "uninstallDisplayName": "Boilerplate App"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "your-org",
        "repo": "your-repo"
      }
    ]
  }
}

# Copy this file to `.keystore-env` and fill in real values.
# NEVER commit `.keystore-env` — it's in .gitignore.

# Absolute path to your release keystore .jks file
ANDROID_KEYSTORE_PATH=C:\path\to\release.jks

# Keystore password
ANDROID_KEYSTORE_PASSWORD=

# Key alias inside the keystore
ANDROID_KEY_ALIAS=boilerplate-release

# Password for the key alias (often same as keystore password)
ANDROID_KEY_PASSWORD=
